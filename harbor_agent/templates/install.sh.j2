#!/bin/bash
# Install script for AttractorCLI agent in Harbor containers

set -euo pipefail

echo "=== Installing AttractorCLI Agent ==="

INSTALL_DIR="/opt/attractor"
mkdir -p "${INSTALL_DIR}/bin"
mkdir -p "${INSTALL_DIR}/workflows"

apt-get update -qq
apt-get install -y -qq curl ca-certificates > /dev/null 2>&1 || true

# Download pre-built binary from GitHub Releases
ATTRACTOR_VERSION="${ATTRACTOR_VERSION:-v0.0.4}"
ATTRACTOR_BINARY_URL="${ATTRACTOR_BINARY_URL:-https://github.com/navanchauhan/swift-omnikit/releases/download/${ATTRACTOR_VERSION}/AttractorCLI-linux-x86_64.tar.gz}"

echo "Downloading AttractorCLI ${ATTRACTOR_VERSION} from ${ATTRACTOR_BINARY_URL}..."
if curl -fsSL "${ATTRACTOR_BINARY_URL}" -o /tmp/attractor.tar.gz; then
    tar xzf /tmp/attractor.tar.gz -C "${INSTALL_DIR}/bin/"
    chmod +x "${INSTALL_DIR}/bin/AttractorCLI"
    rm /tmp/attractor.tar.gz
    echo "Binary installed successfully"
else
    echo "WARNING: Failed to download binary from ${ATTRACTOR_BINARY_URL}"
    echo "Set ATTRACTOR_BINARY_URL or place binary at ${INSTALL_DIR}/bin/AttractorCLI"
fi

# Create the consensus_task.dot workflow
echo "Creating consensus_task.dot workflow..."
cat > "${INSTALL_DIR}/workflows/consensus_task.dot" << 'WORKFLOW_EOF'
digraph Workflow {
  graph [
    label="Consensus Task Workflow",
    goal="$task",
    default_max_retry=3,
    retry_target="CheckDoD",
    fallback_retry_target="Start",
    default_fidelity="truncate"
  ];

  // ── Entry ──
  Start [
    shape=Mdiamond, label="Start",
    type="start"
  ];

  // ── Check if Definition-of-Done was provided ──
  CheckDoD [
    shape=box, label="Check DoD",
    type="codergen",
    llm_provider="anthropic", llm_model="claude-opus-4-6",
    max_agent_turns=2, timeout=120s,
    prompt="Check if a definition of done was provided.\n\nTASK: $task\nDOD: $definition_of_done\n\nIf the DOD is empty or just a placeholder, write a status.json file containing {\"outcome\": \"needs_dod\"}.\nOtherwise write {\"outcome\": \"has_dod\"}."
  ];

  // ── Define DoD (parallel, 3 models) ──
  DefineDoD_Gemini [
    shape=box, label="Define DoD (Gemini)",
    type="codergen",
    llm_provider="gemini", llm_model="gemini-3.1-pro-preview",
    max_agent_turns=6, timeout=5m,
    prompt="Propose a concrete, testable definition of done for this task.\n\nTASK: $task\n\nWrite your proposal to .ai/dod_gemini.md"
  ];

  DefineDoD_GPT [
    shape=box, label="Define DoD (GPT)",
    type="codergen",
    llm_provider="openai", llm_model="gpt-5.4",
    max_agent_turns=6, timeout=5m, reasoning_effort="high",
    prompt="Propose a concrete, testable definition of done for this task.\n\nTASK: $task\n\nWrite your proposal to .ai/dod_gpt.md"
  ];

  DefineDoD_Opus [
    shape=box, label="Define DoD (Opus)",
    type="codergen",
    llm_provider="anthropic", llm_model="claude-opus-4-6",
    max_agent_turns=6, timeout=5m,
    prompt="Propose a concrete, testable definition of done for this task.\n\nTASK: $task\n\nWrite your proposal to .ai/dod_opus.md"
  ];

  ConsolidateDoD [
    shape=box, label="Consolidate DoD",
    type="codergen",
    llm_provider="anthropic", llm_model="claude-opus-4-6",
    max_agent_turns=8, timeout=7m,
    prompt="Synthesize three definition-of-done proposals into one consensus DoD.\n\nTASK: $task\n\nRead .ai/dod_gemini.md, .ai/dod_gpt.md, and .ai/dod_opus.md.\nWrite the consolidated definition of done to .ai/definition_of_done.md"
  ];

  // ── Plan (parallel, 3 models) ──
  PlanGemini [
    shape=box, label="Plan (Gemini)",
    type="codergen",
    llm_provider="gemini", llm_model="gemini-3.1-pro-preview",
    max_agent_turns=8, timeout=7m,
    prompt="Create an implementation plan for this task.\n\nTASK: $task\nDOD: Read .ai/definition_of_done.md (or use: $definition_of_done)\n\nWrite your plan to .ai/plan_gemini.md"
  ];

  PlanGPT [
    shape=box, label="Plan (GPT)",
    type="codergen",
    llm_provider="openai", llm_model="gpt-5.4",
    max_agent_turns=8, timeout=7m, reasoning_effort="high",
    prompt="Create an implementation plan for this task.\n\nTASK: $task\nDOD: Read .ai/definition_of_done.md (or use: $definition_of_done)\n\nWrite your plan to .ai/plan_gpt.md"
  ];

  PlanOpus [
    shape=box, label="Plan (Opus)",
    type="codergen",
    llm_provider="anthropic", llm_model="claude-opus-4-6",
    max_agent_turns=8, timeout=7m,
    prompt="Create an implementation plan for this task.\n\nTASK: $task\nDOD: Read .ai/definition_of_done.md (or use: $definition_of_done)\n\nWrite your plan to .ai/plan_opus.md"
  ];

  DebateConsolidate [
    shape=box, label="Debate & Consolidate",
    type="codergen",
    llm_provider="anthropic", llm_model="claude-opus-4-6",
    max_agent_turns=10, timeout=10m,
    prompt="Synthesize three independent plans into one final implementation plan.\n\nTASK: $task\n\nRead .ai/plan_gemini.md, .ai/plan_gpt.md, and .ai/plan_opus.md.\nIdentify the strongest ideas from each, resolve conflicts, and write the consolidated plan to .ai/plan_final.md"
  ];

  // ── Implement ──
  Implement [
    shape=box, label="Implement (Opus)",
    type="codergen",
    llm_provider="anthropic", llm_model="claude-opus-4-6",
    max_agent_turns=25, timeout=20m, allow_partial=true,
    prompt="Execute the implementation plan.\n\nTASK: $task\n\nFollow .ai/plan_final.md step by step. Log progress to .ai/implementation_log.md"
  ];

  // ── Review (parallel, 3 models) ──
  ReviewGemini [
    shape=box, label="Review (Gemini)",
    type="codergen",
    llm_provider="gemini", llm_model="gemini-3.1-pro-preview",
    max_agent_turns=6, timeout=5m,
    prompt="Review the implementation against the task and definition of done.\n\nTASK: $task\n\nRead the code changes and .ai/definition_of_done.md.\nWrite your review to .ai/review_gemini.md. End with a clear PASS or FAIL verdict."
  ];

  ReviewGPT [
    shape=box, label="Review (GPT)",
    type="codergen",
    llm_provider="openai", llm_model="gpt-5.4",
    max_agent_turns=6, timeout=5m, reasoning_effort="high",
    prompt="Review the implementation against the task and definition of done.\n\nTASK: $task\n\nRead the code changes and .ai/definition_of_done.md.\nWrite your review to .ai/review_gpt.md. End with a clear PASS or FAIL verdict."
  ];

  ReviewOpus [
    shape=box, label="Review (Opus)",
    type="codergen",
    llm_provider="anthropic", llm_model="claude-opus-4-6",
    max_agent_turns=6, timeout=5m,
    prompt="Review the implementation against the task and definition of done.\n\nTASK: $task\n\nRead the code changes and .ai/definition_of_done.md.\nWrite your review to .ai/review_opus.md. End with a clear PASS or FAIL verdict."
  ];

  // ── Review Consensus (steering node) ──
  ReviewConsensus [
    shape=box, label="Review Consensus",
    type="codergen",
    llm_provider="anthropic", llm_model="claude-opus-4-6",
    max_agent_turns=6, timeout=5m,
    prompt="Reach a consensus verdict from three independent reviews.\n\nRead .ai/review_gemini.md, .ai/review_gpt.md, and .ai/review_opus.md.\nWrite the consensus to .ai/review_consensus.md.\n\nThen write status.json: {\"outcome\": \"yes\"} if the consensus is PASS, or {\"outcome\": \"retry\"} if FAIL."
  ];

  // ── Postmortem (on failure) ──
  Postmortem [
    shape=box, label="Postmortem",
    type="codergen",
    llm_provider="anthropic", llm_model="claude-opus-4-6",
    max_agent_turns=8, timeout=7m,
    prompt="Conduct a failure postmortem.\n\nTASK: $task\n\nRead .ai/review_consensus.md and .ai/implementation_log.md.\nAnalyze root causes and write actionable improvements to .ai/postmortem.md"
  ];

  // ── Exit ──
  Done [
    shape=Msquare, label="Done",
    type="exit"
  ];

  // ── Edges ──
  Start -> CheckDoD;

  CheckDoD -> DefineDoD_Gemini [condition="outcome=needs_dod"];
  CheckDoD -> DefineDoD_GPT    [condition="outcome=needs_dod"];
  CheckDoD -> DefineDoD_Opus   [condition="outcome=needs_dod"];
  CheckDoD -> PlanGemini       [condition="outcome=has_dod"];
  CheckDoD -> PlanGPT          [condition="outcome=has_dod"];
  CheckDoD -> PlanOpus         [condition="outcome=has_dod"];

  DefineDoD_Gemini -> ConsolidateDoD;
  DefineDoD_GPT    -> ConsolidateDoD;
  DefineDoD_Opus   -> ConsolidateDoD;

  ConsolidateDoD -> PlanGemini;
  ConsolidateDoD -> PlanGPT;
  ConsolidateDoD -> PlanOpus;

  PlanGemini -> DebateConsolidate;
  PlanGPT    -> DebateConsolidate;
  PlanOpus   -> DebateConsolidate;

  DebateConsolidate -> Implement;

  Implement -> ReviewGemini;
  Implement -> ReviewGPT;
  Implement -> ReviewOpus;

  ReviewGemini -> ReviewConsensus;
  ReviewGPT    -> ReviewConsensus;
  ReviewOpus   -> ReviewConsensus;

  ReviewConsensus -> Done       [condition="outcome=yes"];
  ReviewConsensus -> Postmortem [condition="outcome=retry"];

  Postmortem -> PlanGemini [loop_restart=true];
  Postmortem -> PlanGPT    [loop_restart=true];
  Postmortem -> PlanOpus   [loop_restart=true];
}
WORKFLOW_EOF

ln -sf "${INSTALL_DIR}/bin/AttractorCLI" /usr/local/bin/AttractorCLI 2>/dev/null || true
echo "export PATH=\"${INSTALL_DIR}/bin:\${PATH}\"" >> /etc/bash.bashrc

echo "=== Installation Complete ==="
echo "Workflow: ${INSTALL_DIR}/workflows/consensus_task.dot"

if [ -f "${INSTALL_DIR}/bin/AttractorCLI" ]; then
    echo "Binary: ${INSTALL_DIR}/bin/AttractorCLI"
    "${INSTALL_DIR}/bin/AttractorCLI" --help > /dev/null 2>&1 && echo "Verified: AttractorCLI works" || echo "Warning: AttractorCLI may need dependencies"
else
    echo "NOTE: Binary not installed. Set ATTRACTOR_BINARY_URL or provide manually."
fi
