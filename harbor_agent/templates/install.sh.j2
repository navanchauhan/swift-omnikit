#!/bin/bash
# Install script for AttractorCLI agent in Harbor containers

set -euo pipefail

echo "=== Installing AttractorCLI Agent ==="

INSTALL_DIR="/opt/attractor"
mkdir -p "${INSTALL_DIR}/bin"
mkdir -p "${INSTALL_DIR}/workflows"

apt-get update -qq
apt-get install -y -qq curl ca-certificates > /dev/null 2>&1 || true

# Download pre-built binary from GitHub Releases
ATTRACTOR_VERSION="${ATTRACTOR_VERSION:-v0.0.8}"

# Detect architecture
ARCH=$(uname -m)
case "$ARCH" in
    aarch64|arm64) ARCH_SUFFIX="arm64" ;;
    x86_64|amd64)  ARCH_SUFFIX="x86_64" ;;
    *) echo "Unsupported architecture: $ARCH"; exit 1 ;;
esac

ATTRACTOR_BINARY_URL="${ATTRACTOR_BINARY_URL:-https://github.com/navanchauhan/swift-omnikit/releases/download/${ATTRACTOR_VERSION}/AttractorCLI-linux-${ARCH_SUFFIX}.tar.gz}"

echo "Downloading AttractorCLI ${ATTRACTOR_VERSION} from ${ATTRACTOR_BINARY_URL}..."
if curl -fsSL "${ATTRACTOR_BINARY_URL}" -o /tmp/attractor.tar.gz; then
    tar xzf /tmp/attractor.tar.gz -C "${INSTALL_DIR}/bin/"
    chmod +x "${INSTALL_DIR}/bin/AttractorCLI"
    # Ensure resource bundles are alongside the binary
    ls "${INSTALL_DIR}/bin/"*.resources > /dev/null 2>&1 && echo "Resource bundles found"
    rm /tmp/attractor.tar.gz
    echo "Binary installed successfully"
else
    echo "WARNING: Failed to download binary from ${ATTRACTOR_BINARY_URL}"
    echo "Set ATTRACTOR_BINARY_URL or place binary at ${INSTALL_DIR}/bin/AttractorCLI"
fi

# Create the consensus_task.dot workflow
echo "Creating consensus_task.dot workflow..."
cat > "${INSTALL_DIR}/workflows/consensus_task.dot" << 'WORKFLOW_EOF'
digraph Workflow {
  graph [
    label="Consensus Task Workflow",
    goal="$task",
    default_max_retry=3,
    retry_target="PlanGemini",
    fallback_retry_target="Start",
    default_fidelity="truncate"
  ];

  // ── Entry ──
  Start [
    shape=Mdiamond, label="Start",
    type="start"
  ];

  // ── Plan (parallel, 3 models) ──
  PlanGemini [
    shape=box, label="Plan (Gemini)",
    type="codergen",
    llm_provider="gemini", llm_model="gemini-3.1-pro-preview",
    prompt="You are a planning agent. Explore the codebase/environment and write a SHORT, step-by-step plan to accomplish this task. Focus on the exact commands and file changes needed. Do not implement anything — only plan.\n\nTASK: $task\n\nWrite your plan (max 20 lines) to .ai/plan_gemini.md"
  ];

  PlanGPT [
    shape=box, label="Plan (GPT)",
    type="codergen",
    llm_provider="openai", llm_model="gpt-5.4",
    timeout=10m, reasoning_effort="high",
    prompt="You are a planning agent. Explore the codebase/environment and write a SHORT, step-by-step plan to accomplish this task. Focus on the exact commands and file changes needed. Do not implement anything — only plan.\n\nTASK: $task\n\nWrite your plan (max 20 lines) to .ai/plan_gpt.md"
  ];

  PlanOpus [
    shape=box, label="Plan (Opus)",
    type="codergen",
    llm_provider="anthropic", llm_model="claude-opus-4-6",
    prompt="You are a planning agent. Explore the codebase/environment and write a SHORT, step-by-step plan to accomplish this task. Focus on the exact commands and file changes needed. Do not implement anything — only plan.\n\nTASK: $task\n\nWrite your plan (max 20 lines) to .ai/plan_opus.md"
  ];

  ConsolidatePlan [
    shape=box, label="Consolidate Plan",
    type="codergen",
    llm_provider="anthropic", llm_model="claude-opus-4-6",
    prompt="Read these three plans and merge them into one final plan. PREFER THE SIMPLEST APPROACH — do the minimum necessary to solve the task. If multiple plans suggest different strategies, pick the one with the fewest steps that still solves the problem correctly.\n\nTASK: $task\n\nRead .ai/plan_gemini.md, .ai/plan_gpt.md, .ai/plan_opus.md.\nWrite the final plan to .ai/plan_final.md (max 15 lines, simplest correct approach)."
  ];

  // ── Implement ──
  Implement [
    shape=box, label="Implement (Opus)",
    type="codergen",
    llm_provider="anthropic", llm_model="claude-opus-4-6",
    allow_partial=true,
    prompt="You are an implementation agent. Your job is to EXECUTE the task, not analyze it.\n\nTASK: $task\n\nINSTRUCTIONS:\n1. You may glance at .ai/plan_final.md for ideas, but use your own judgment — do the SIMPLEST thing that solves the task\n2. IMMEDIATELY start executing — run commands, edit files, make changes\n3. Do NOT over-engineer or do extra work beyond what the task asks\n4. After making changes, VERIFY they work (run tests, check output, etc.)\n5. If something fails, fix it and try again\n\nDo the minimum necessary to complete the task correctly. Less is more."
  ];

  // ── Review (parallel, 3 models) ──
  ReviewGemini [
    shape=box, label="Review (Gemini)",
    type="codergen",
    llm_provider="gemini", llm_model="gemini-3.1-pro-preview",
    prompt="Verify the task was completed correctly.\n\nTASK: $task\n\nCheck the actual state of files, git status, command outputs, etc. Do not just read logs — actually verify the work was done.\n\nWrite to .ai/review_gemini.md: what you checked, what you found, and a final PASS or FAIL verdict."
  ];

  ReviewGPT [
    shape=box, label="Review (GPT)",
    type="codergen",
    llm_provider="openai", llm_model="gpt-5.4",
    timeout=10m, reasoning_effort="high",
    prompt="Verify the task was completed correctly.\n\nTASK: $task\n\nCheck the actual state of files, git status, command outputs, etc. Do not just read logs — actually verify the work was done.\n\nWrite to .ai/review_gpt.md: what you checked, what you found, and a final PASS or FAIL verdict."
  ];

  ReviewOpus [
    shape=box, label="Review (Opus)",
    type="codergen",
    llm_provider="anthropic", llm_model="claude-opus-4-6",
    prompt="Verify the task was completed correctly.\n\nTASK: $task\n\nCheck the actual state of files, git status, command outputs, etc. Do not just read logs — actually verify the work was done.\n\nWrite to .ai/review_opus.md: what you checked, what you found, and a final PASS or FAIL verdict."
  ];

  // ── Review Consensus (steering node) ──
  ReviewConsensus [
    shape=box, label="Review Consensus",
    type="codergen",
    llm_provider="anthropic", llm_model="claude-opus-4-6",
    prompt="Read the three review verdicts and decide: is the task done?\n\nRead .ai/review_gemini.md, .ai/review_gpt.md, .ai/review_opus.md.\nWrite consensus to .ai/review_consensus.md.\n\nThen respond with:\n```json\n{\"outcome\": \"yes\", \"notes\": \"task completed\"}\n```\nif at least 2 of 3 reviewers say PASS, or:\n```json\n{\"outcome\": \"retry\", \"notes\": \"task not completed\"}\n```\nif not."
  ];

  // ── Postmortem (on failure) ──
  Postmortem [
    shape=box, label="Postmortem",
    type="codergen",
    llm_provider="anthropic", llm_model="claude-opus-4-6",
    prompt="The implementation failed review. Read .ai/review_consensus.md to understand why.\n\nTASK: $task\n\nWrite a brief (10 lines max) action plan to .ai/postmortem.md explaining exactly what needs to be fixed."
  ];

  // ── Exit ──
  Done [
    shape=Msquare, label="Done",
    type="exit"
  ];

  // ── Edges ──
  Start -> PlanGemini;
  Start -> PlanGPT;
  Start -> PlanOpus;

  PlanGemini -> ConsolidatePlan;
  PlanGPT    -> ConsolidatePlan;
  PlanOpus   -> ConsolidatePlan;

  ConsolidatePlan -> Implement;

  Implement -> ReviewGemini;
  Implement -> ReviewGPT;
  Implement -> ReviewOpus;

  ReviewGemini -> ReviewConsensus;
  ReviewGPT    -> ReviewConsensus;
  ReviewOpus   -> ReviewConsensus;

  ReviewConsensus -> Done       [condition="outcome=yes"];
  ReviewConsensus -> Postmortem [condition="outcome=retry"];

  Postmortem -> PlanGemini [loop_restart=true];
  Postmortem -> PlanGPT    [loop_restart=true];
  Postmortem -> PlanOpus   [loop_restart=true];
}
WORKFLOW_EOF

# Create a single-agent workflow (faster, for simpler tasks)
echo "Creating single_agent.dot workflow..."
cat > "${INSTALL_DIR}/workflows/single_agent.dot" << 'WORKFLOW_EOF'
digraph Workflow {
  graph [
    label="Single Agent Workflow",
    goal="$task"
  ];

  Start [
    shape=Mdiamond, label="Start",
    type="start"
  ];

  Implement [
    shape=box, label="Implement",
    type="codergen",
    llm_provider="anthropic", llm_model="claude-opus-4-6",
    allow_partial=true,
    prompt="Complete the following task. Read the relevant files, understand the codebase, and make the necessary changes.\n\nTASK: $task"
  ];

  Done [
    shape=Msquare, label="Done",
    type="exit"
  ];

  Start -> Implement;
  Implement -> Done;
}
WORKFLOW_EOF

ln -sf "${INSTALL_DIR}/bin/AttractorCLI" /usr/local/bin/AttractorCLI 2>/dev/null || true
echo "export PATH=\"${INSTALL_DIR}/bin:\${PATH}\"" >> /etc/bash.bashrc

echo "=== Installation Complete ==="
echo "Workflows: ${INSTALL_DIR}/workflows/"

if [ -f "${INSTALL_DIR}/bin/AttractorCLI" ]; then
    echo "Binary: ${INSTALL_DIR}/bin/AttractorCLI"
    "${INSTALL_DIR}/bin/AttractorCLI" --help > /dev/null 2>&1 && echo "Verified: AttractorCLI works" || echo "Warning: AttractorCLI may need dependencies"
else
    echo "NOTE: Binary not installed. Set ATTRACTOR_BINARY_URL or provide manually."
fi
