digraph SemportThematic {
  graph [
    label="$target_name Thematic Semport (Agentic Loop)",
    goal="Port $source_ref into $target_name via evolving thematic checklist and iterative implementation/validation.",
    source_ref="references/openai-agents-python",
    target_module="Sources/OmniAgentsSDK",
    target_name="OmniAgentsSDK",
    rankdir=LR,
    default_max_retry=5,
    retry_target="PlanParallel",
    fallback_retry_target="Start"
  ];

  Start [shape=Mdiamond, label="Start"];
  Exit [shape=Msquare, label="Exit"];

  EnsureWorkspace [
    shape=parallelogram,
    label="Ensure semport workspace files",
    tool_command="set -eu\nmkdir -p .ai/semport/$target_name\nif [ ! -f .ai/semport/$target_name/thematic-spec.md ]; then\n  cat > .ai/semport/$target_name/thematic-spec.md <<'SPECEOF'\n# $target_name Thematic Semport Spec\n\n## Scope\n- Semantic port of $source_ref into $target_module.\n\n## Checklist\n<!-- planner maintains checklist here -->\n\n## Validation Feedback\n<!-- validator/appraiser writes concise latest loop feedback here -->\nSPECEOF\nfi\nif [ ! -f .ai/semport/$target_name/validation-feedback.md ]; then\n  cat > .ai/semport/$target_name/validation-feedback.md <<'FBEOF'\n# Validation Feedback\n- none yet\nFBEOF\nfi\nprintf 'workspace ready'"
  ];

  PlanParallel [shape=component, label="Plan Thematic Checklist (Parallel)"];

  PlanGPT [
    shape=box,
    label="Plan Themes (GPT-5.2)",
    llm_provider="openai",
    llm_model="gpt-5.2",
    reasoning_effort="high",
    auto_status=true,
    prompt="Use tools to inspect $source_ref and $target_module. Propose thematic sections and a concrete markdown checklist for semantic porting. Create a numbered artifact `.ai/semport/$target_name/plan-gpt-NNN.md` where NNN is next zero-padded index (scan existing plan-gpt-*.md, max+1, start 001). If .ai/semport/$target_name/thematic-spec.md already exists, UPDATE it in-place and preserve completed items; do not rewrite from scratch. Consume .ai/semport/$target_name/validation-feedback.md and fold its failures/gaps into checklist updates. Output concise rationale and what changed."
  ];

  PlanOpus [
    shape=box,
    label="Plan Themes (Opus-4.6)",
    llm_provider="anthropic",
    llm_model="claude-opus-4-6",
    reasoning_effort="high",
    auto_status=true,
    prompt="Use tools to inspect $source_ref and $target_module. Propose thematic sections and a concrete markdown checklist for semantic porting. Create a numbered artifact `.ai/semport/$target_name/plan-opus-NNN.md` where NNN is next zero-padded index (scan existing plan-opus-*.md, max+1, start 001). If .ai/semport/$target_name/thematic-spec.md already exists, UPDATE it in-place and preserve completed items; do not rewrite from scratch. Consume .ai/semport/$target_name/validation-feedback.md and fold its failures/gaps into checklist updates. Output concise rationale and what changed."
  ];

  PlanGemini [
    shape=box,
    label="Plan Themes (Gemini 3.1 Pro)",
    llm_provider="gemini",
    llm_model="gemini-3.1-pro-preview-customtools",
    reasoning_effort="high",
    auto_status=true,
    prompt="Use tools to inspect $source_ref and $target_module. Propose thematic sections and a concrete markdown checklist for semantic porting. Create a numbered artifact `.ai/semport/$target_name/plan-gemini-NNN.md` where NNN is next zero-padded index (scan existing plan-gemini-*.md, max+1, start 001). If .ai/semport/$target_name/thematic-spec.md already exists, UPDATE it in-place and preserve completed items; do not rewrite from scratch. Consume .ai/semport/$target_name/validation-feedback.md and fold its failures/gaps into checklist updates. Output concise rationale and what changed."
  ];

  PlanJoin [shape=tripleoctagon, label="Plan Join"];

  ConsolidatePlan [
    shape=box,
    label="Consolidate Plan Into Spec (Opus)",
    llm_provider="anthropic",
    llm_model="claude-opus-4-6",
    reasoning_effort="high",
    auto_status=true,
    prompt="Using parallel planner outputs and repository inspection via tools, consolidate into .ai/semport/$target_name/thematic-spec.md. Also write snapshot `.ai/semport/$target_name/thematic-spec-NNN.md` where NNN is next zero-padded index (scan thematic-spec-*.md, max+1, start 001). Maintain one authoritative checklist with explicit [ ] and [x] items grouped by theme. Keep completed checks intact. Add a short 'Next implementation target' section naming exactly one checklist slice to implement next."
  ];

  ImplementSlice [
    shape=box,
    label="Implement Next Checklist Slice (GPT-5.3 Codex)",
    llm_provider="openai",
    llm_model="gpt-5.3-codex",
    reasoning_effort="high",
    auto_status=true,
    allow_partial=true,
    prompt="Read .ai/semport/$target_name/thematic-spec.md and implement the highest-priority unchecked checklist slices in $target_module using semantic parity with $source_ref. Tackle as many related items as you can in one pass while keeping the build green. Discover needed files yourself via tools; do not expect preloaded file dumps. Make concrete code changes, then mark only truly completed checklist entries as [x]. Write a short implementation note section into .ai/semport/$target_name/thematic-spec.md describing what changed. Also write `.ai/semport/$target_name/implement-NNN.md` where NNN is next zero-padded index (scan implement-*.md, max+1, start 001) containing changed files, tests/build commands run, and any blockers."
  ];

  BuildGate [
    shape=parallelogram,
    label="Build gate (must pass)",
    tool_command="set -eu\nswift build --target $target_name >/tmp/semport-thematic-$target_name-build.log 2>&1 || {\n  printf 'BUILD_FAIL\\n'\n  grep 'error:' /tmp/semport-thematic-$target_name-build.log | head -80 || true\n  exit 1\n}\nprintf 'BUILD_PASS'"
  ];

  ValidateParallel [shape=component, label="Validate Implementation (Parallel)"];

  ValidateGPT [
    shape=box,
    label="Validate (GPT-5.2)",
    llm_provider="openai",
    llm_model="gpt-5.2",
    reasoning_effort="high",
    auto_status=true,
    prompt="Validate the latest implementation against .ai/semport/$target_name/thematic-spec.md and $source_ref by using tools. Report missing behavior, incomplete checklist claims, and concrete evidence commands/files. Write findings to numbered artifact `.ai/semport/$target_name/validation-gpt-NNN.md` where NNN is next zero-padded index (scan validation-gpt-*.md, max+1, start 001)."
  ];

  ValidateOpus [
    shape=box,
    label="Validate (Opus-4.6)",
    llm_provider="anthropic",
    llm_model="claude-opus-4-6",
    reasoning_effort="high",
    auto_status=true,
    prompt="Validate the latest implementation against .ai/semport/$target_name/thematic-spec.md and $source_ref by using tools. Report missing behavior, incomplete checklist claims, and concrete evidence commands/files. Write findings to numbered artifact `.ai/semport/$target_name/validation-opus-NNN.md` where NNN is next zero-padded index (scan validation-opus-*.md, max+1, start 001)."
  ];

  ValidateGemini [
    shape=box,
    label="Validate (Gemini 3.1 Pro)",
    llm_provider="gemini",
    llm_model="gemini-3.1-pro-preview-customtools",
    reasoning_effort="high",
    auto_status=true,
    prompt="Validate the latest implementation against .ai/semport/$target_name/thematic-spec.md and $source_ref by using tools. Report missing behavior, incomplete checklist claims, and concrete evidence commands/files. Write findings to numbered artifact `.ai/semport/$target_name/validation-gemini-NNN.md` where NNN is next zero-padded index (scan validation-gemini-*.md, max+1, start 001)."
  ];

  ValidateJoin [shape=tripleoctagon, label="Validation Join"];

  ConsolidateValidation [
    shape=box,
    label="Consolidate Validation + Update Spec (Opus)",
    llm_provider="anthropic",
    llm_model="claude-opus-4-6",
    reasoning_effort="high",
    auto_status=true,
    prompt="Consolidate validation outputs from all three validators. Write numbered consensus artifact `.ai/semport/$target_name/validation-consensus-NNN.md` where NNN is next zero-padded index (scan validation-consensus-*.md, max+1, start 001). Update .ai/semport/$target_name/validation-feedback.md with precise failure reasons and what to fix next. Then update .ai/semport/$target_name/thematic-spec.md in-place: keep truthful [x], revert any invalid completion to [ ], and add/refine checklist items based on discovered gaps. Do not rewrite whole file if it already exists."
  ];

  CheckCompletion [
    shape=parallelogram,
    label="Check if checklist fully complete",
    tool_command="set -eu\nif rg -n '^- \\[ \\]' .ai/semport/$target_name/thematic-spec.md >/dev/null 2>&1; then\n  printf 'INCOMPLETE'\n  exit 1\nfi\nprintf 'COMPLETE'"
  ];

  Start -> EnsureWorkspace;
  EnsureWorkspace -> PlanParallel;

  PlanParallel -> PlanGPT;
  PlanParallel -> PlanOpus;
  PlanParallel -> PlanGemini;
  PlanGPT -> PlanJoin;
  PlanOpus -> PlanJoin;
  PlanGemini -> PlanJoin;

  PlanJoin -> ConsolidatePlan;
  ConsolidatePlan -> ImplementSlice;

  ImplementSlice -> BuildGate;
  BuildGate -> ValidateParallel [condition="outcome=success", label="build_passed"];
  BuildGate -> PlanParallel [condition="outcome=fail", label="build_failed_replan", loop_restart=true];
  ValidateParallel -> ValidateGPT;
  ValidateParallel -> ValidateOpus;
  ValidateParallel -> ValidateGemini;
  ValidateGPT -> ValidateJoin;
  ValidateOpus -> ValidateJoin;
  ValidateGemini -> ValidateJoin;

  ValidateJoin -> ConsolidateValidation;
  ConsolidateValidation -> CheckCompletion;

  CheckCompletion -> Exit [condition="outcome=success", label="all_checked_and_validated"];
  CheckCompletion -> PlanParallel [condition="outcome=fail", label="needs_more_porting", loop_restart=true];
}
